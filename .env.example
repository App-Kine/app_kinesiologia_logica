# ============================================================================
# Auris · Capa Lógica (backend de datos)  —  variables de entorno de PRODUCCIÓN
# ----------------------------------------------------------------------------
# Copiar a .env (o exportar en el entorno del proceso) y completar los valores.
# En DESARROLLO se usan env/local.js / env/development.js (no hace falta .env).
# Esta capa NO debe exponerse a internet: solo la alcanza el Controlador.
# ============================================================================

# Servicio
PORT=2000
NODE_ENV=production

# --- SQL Server ---
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASS=
DB_NAME=AurisDB

# --- MongoDB (multimedia, GridFS) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=auris_media

# --- Autenticación ---
# JWT_SECRET DEBE coincidir EXACTAMENTE con el del Controlador. Fuerte y único.
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# --- Correo saliente (informes a estudiantes + invitaciones a profesores) ---
# MAIL_MODE=console  → no envía, solo loguea (útil para revisión sin SMTP real)
# MAIL_MODE=smtp     → envía de verdad usando las credenciales de abajo
MAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=AURIS <no-reply@uv.cl>

# URL del Panel (para los links de invitación que se envían por correo)
FRONTEND_BASE_URL=https://panel.uv.cl

# Orígenes CORS permitidos (la app/panel suben multimedia directo a esta capa)
CORS_ORIGINS=https://panel.uv.cl,https://app.uv.cl

# Vencimiento de las invitaciones de profesor (horas).
# La lógica lo limita a un MÁXIMO de 48h (RNF-12): valores mayores se recortan a 48.
INVITACION_EXPIRA_HORAS=24

# Logs estructurados en JSON (1 = sí)
LOG_JSON=1
