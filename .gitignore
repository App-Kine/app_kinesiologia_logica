# =============================================================================
# Auris · Capa Lógica — .gitignore
# =============================================================================
# Node.js + Express + mssql
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencias
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/

# Lock file (convención del equipo: no versionarlo)
package-lock.json
yarn.lock

# ---------------------------------------------------------------------------
# Credenciales y secretos (NUNCA al repo)
# ---------------------------------------------------------------------------
/env/local.js
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Builds, outputs y cachés
# ---------------------------------------------------------------------------
dist/
build/
out/
.cache/

# ---------------------------------------------------------------------------
# Tests y cobertura
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/

# ---------------------------------------------------------------------------
# Database dumps binarios (los .sql canónicos SÍ se versionan)
# ---------------------------------------------------------------------------
*.bak
*.dump
database/*.bak
database/backups/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Archivos del sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Editores e IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.history/
.fleet/

# ---------------------------------------------------------------------------
# Temporales
# ---------------------------------------------------------------------------
.tmp/
tmp/
temp/
*.tmp
*.temp
