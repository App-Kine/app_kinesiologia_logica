# =============================================================================
# Auris · Capa Lógica — .gitignore
# Node.js + Express + mssql + MongoDB
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencias
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/

# Lock file (convención del equipo: no versionarlo)
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Credenciales y secretos (NUNCA al repo)
# Acá viven connection strings de SQL, Mongo, SMTP, JWT secret, etc.
# Se versiona env/local.js.example como plantilla.
# -----------------------------------------------------------------------------
/env/local.js
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Builds, outputs y cachés
# -----------------------------------------------------------------------------
dist/
build/
out/
.cache/
.tmp/

# -----------------------------------------------------------------------------
# Tests y cobertura
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
junit.xml

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Database dumps binarios y backups
# (los .sql canónicos del schema SÍ se versionan)
# -----------------------------------------------------------------------------
*.bak
*.dump
database/*.bak
database/backups/

# -----------------------------------------------------------------------------
# IDEs / Editores
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.history/
*.swp
*~

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Carpetas basura cuando Windows leakea rutas absolutas en otro OS
# -----------------------------------------------------------------------------
/C:/
