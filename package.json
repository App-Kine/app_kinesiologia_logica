{
  "name": "base_logica",
  "base_version": "3.0.0",
  "version": "1.0.5",
  "description": "base logica",
  "main": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "dev": "SET NODE_ENV=development & nodemon index.js",
    "prod": "SET NODE_ENV=production & nodemon index.js",
    "dev-unix": "NODE_ENV=development nodemon index.js",
    "prod-unix": "NODE_ENV=production nodemon index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prettier-c": "prettier --check .",
    "prettier-w": "prettier --write ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "proyecto/services/**/*.js",
      "proyecto/repositories/**/*.js",
      "!proyecto/services/multimedia.service.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 60,
        "statements": 60
      }
    },
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "author": "CIDUV",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dateformat": "^4.5.1",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.3",
    "method-override": "^3.0.0",
    "mongodb": "^6.21.0",
    "mssql": "^8.1.3",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.6.1",
    "nodemailer": "^8.0.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^2.0.14",
    "prettier": "^2.6.2"
  }
}
